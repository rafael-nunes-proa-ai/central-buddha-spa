# ============================================================================
# AWS CREDENTIALS (para AWS Bedrock - Claude)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui

# ============================================================================
# Google Maps API Key
# ============================================================================
# Obtenha em: https://console.cloud.google.com/
# 1. Crie um projeto no Google Cloud Platform
# 2. Ative as APIs: Geocoding API e Distance Matrix API (opcional)
# 3. Crie credenciais (API Key)
# 4. Cole abaixo e renomeie este arquivo para .env
# 
# MODELO 2025 (a partir de 1º de março de 2025):
# - Geocoding API (Essentials): 10.000 requisições GRÁTIS/mês
# - Após 10.000: $5 por 1.000 requisições (até 100k)
# - Após 100.000: $4 por 1.000 requisições (até 500k)
# - Distance Matrix API: PAGO desde a 1ª requisição ($5/1k até 100k)
# 
# Fonte: https://developers.google.com/maps/billing-and-pricing/faq

GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui

# ============================================================================
# BANCO DE DADOS POSTGRESQL
# ============================================================================
# Para Docker: use postgres_central
# Para local: use localhost
DB_HOST=postgres_central
DB_PORT=5432
DB_NAME=bot_central
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================================
# API
# ============================================================================
PORT=8081
API_KEY=seu_api_key_secreto_aqui

# ============================================================================
# AMBIENTE
# ============================================================================
ENV=dev
