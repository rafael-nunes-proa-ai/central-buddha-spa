# ============================================================================
# AWS CREDENTIALS (para AWS Bedrock - Claude)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui

# ============================================================================
# LocationIQ API Key
# ============================================================================
# Obtenha gratuitamente em: https://locationiq.com/
# 1. Crie uma conta gratuita
# 2. Acesse o dashboard
# 3. Copie sua API Key
# 4. Cole abaixo e renomeie este arquivo para .env

LOCATIONIQ_API_KEY=pk.bf718fb5a04e7bbcf966c0c013242a8a

# ============================================================================
# BANCO DE DADOS POSTGRESQL
# ============================================================================
# Para Docker: use postgres_central
# Para local: use localhost
DB_HOST=postgres_central
DB_PORT=5432
DB_NAME=bot_central
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================================
# API
# ============================================================================
PORT=8081
API_KEY=seu_api_key_secreto_aqui

# ============================================================================
# AMBIENTE
# ============================================================================
ENV=dev
